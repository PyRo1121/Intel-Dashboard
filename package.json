{
  "name": "intel-dashboard-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.8",
  "dependencies": {
    "@intel-dashboard/shared": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --cwd apps/web dev",
    "generate:seo-assets": "node --experimental-strip-types scripts/generate-seo-assets.ts",
    "build": "bun run build:web",
    "build:web": "bun run generate:seo-assets && bun run --cwd apps/web build",
    "start:web": "bun run --cwd apps/web start",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:edge": "bun run --cwd apps/edge typecheck",
    "typecheck:backend": "bun run --cwd apps/backend typecheck",
    "typecheck": "bun run typecheck:web && bun run typecheck:edge && bun run typecheck:backend",
    "test:web": "bun run --cwd apps/web test:app",
    "test:edge": "bun run --cwd apps/edge test",
    "test:backend": "bun run --cwd apps/backend test",
    "test:e2e": "node scripts/run-e2e-with-dev-vars.mjs",
    "test:e2e:browser": "node scripts/run-e2e-with-dev-vars.mjs --test e2e/browser-smoke.test.mjs",
    "test:e2e:owner-admin": "node scripts/run-e2e-with-dev-vars.mjs --test e2e/browser-owner-admin.test.mjs",
    "test:e2e:backend-api": "node scripts/run-e2e-with-dev-vars.mjs --test e2e/backend-api-smoke.test.mjs",
    "test:e2e:public-browser": "node scripts/run-e2e-with-dev-vars.mjs --test e2e/browser-public.test.mjs",
    "test:e2e:strict": "E2E_STRICT=1 node scripts/run-e2e-with-dev-vars.mjs",
    "test:e2e:auth": "E2E_STRICT=1 E2E_REQUIRE_AUTH=1 node scripts/run-e2e-with-dev-vars.mjs",
    "test": "bun run test:web && bun run test:edge && bun run test:backend",
    "test:all": "bun run check:repo-hygiene && bun run check:secrets && bun run check:typegen && bun run typecheck && bun run test && bun run test:e2e && bun run test:e2e:browser",
    "test:all:strict": "bun run check:repo-hygiene && bun run check:secrets && bun run check:typegen && bun run typecheck && bun run test && bun run test:e2e:strict && bun run test:e2e:browser",
    "test:all:live": "E2E_STRICT=1 E2E_REQUIRE_AUTH=1 bun run check:e2e-live && bun run test:all",
    "check:secrets": "node scripts/check-wrangler-secrets.mjs",
    "check:typegen": "node scripts/check-cloudflare-typegen-sync.mjs",
    "check:repo-hygiene": "node scripts/check-repo-hygiene.mjs",
    "check:e2e-live": "node --experimental-strip-types scripts/check-e2e-live-config.mjs",
    "check:e2e-owner-admin-live": "node --experimental-strip-types scripts/check-e2e-owner-admin-live-config.mjs",
    "check:e2e-backend-api-live": "node --experimental-strip-types scripts/check-e2e-backend-api-live-config.mjs",
    "bench:latency": "node --experimental-strip-types scripts/benchmark-latency.mjs",
    "bench:assert": "node scripts/compare-benchmarks.mjs",
    "security:cf:apply": "node scripts/cloudflare-hardening.mjs",
    "security:cf:verify": "node scripts/cloudflare-security-verify.mjs",
    "security:cf:allow-owner-e2e-ip": "node scripts/cloudflare-allow-owner-e2e-ip.mjs",
    "security:cf:clear-owner-e2e-ip": "node scripts/cloudflare-clear-owner-e2e-ip.mjs",
    "billing:stripe:setup": "node --experimental-strip-types scripts/stripe-cli-setup.mjs",
    "e2e:save-secrets": "node --experimental-strip-types scripts/save-e2e-secrets.mjs",
    "admin:sign": "node --experimental-strip-types apps/edge/sign-admin-request.ts",
    "health:oauth": "node --experimental-strip-types apps/edge/test/oauth-health-check.ts",
    "typegen:cf": "apps/edge/node_modules/.bin/wrangler types apps/edge/worker-configuration.d.ts -c apps/edge/wrangler.toml -c apps/backend/wrangler.jsonc && apps/backend/node_modules/.bin/wrangler types apps/backend/worker-configuration.d.ts -c apps/backend/wrangler.jsonc",
    "deploy:edge": "bun run --cwd apps/edge deploy",
    "deploy:backend": "bun run --cwd apps/backend deploy"
  }
}
